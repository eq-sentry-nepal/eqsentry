# ── EQ Sentry backend configuration ───────────────────────────────────────
# Copy this file to ".env" and fill in your values. Never commit the real .env.

# Server
PORT=8787
PUBLIC_BASE_URL=https://eqsentry.com        # used to build confirm/unsubscribe links
ALLOW_ORIGIN=https://eqsentry.com           # CORS origin for the website (use * for local testing)

# Alert region + rules (Nepal bounding box)
REGION_MIN_LAT=26
REGION_MAX_LAT=31
REGION_MIN_LON=79
REGION_MAX_LON=89
DEFAULT_RADIUS_KM=150                        # alert if quake within this distance of a subscriber's district
USGS_FEED=2.5_hour                           # which USGS feed the engine polls (e.g. 2.5_hour, 4.5_day)

# Status sampling & admin API
STATUS_POLL_SECONDS=300                       # how often the server probes USGS/EMSC for uptime history
ADMIN_KEY=                                    # required to read /api/status/* in production (any long secret)

# Run the alert engine automatically inside the server process?
ALERT_POLL=true
ALERT_POLL_SECONDS=120                        # how often to poll USGS

# ── SMS via Sparrow SMS (Nepal) ──  https://sparrowsms.com
SPARROW_TOKEN=
SPARROW_FROM=Demo                             # your approved sender identity

# ── Email via SMTP (any provider) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="EQ Sentry <alerts@eqsentry.com>"

# ── Viber / WhatsApp (optional; stubs provided) ──
VIBER_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── Browser push (Web Push / VAPID) ──  free, no SMS/email needed
# Generate a keypair ONCE, then paste both values here:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:alerts@eqsentry.com       # a mailto: address or your site URL
